<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root application menu -->
    <menuitem
        id="menu_fms_root"
        name="Forecourt Station"
        sequence="50"
    />

    <!-- Placeholder action — opens native res.company list/form (replaced in Task 1.1) -->
    <record id="action_fms_placeholder_companies" model="ir.actions.act_window">
        <field name="name">Companies</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Operations — day-to-day shift management -->
    <menuitem
        id="menu_fms_operations"
        name="Operations"
        parent="menu_fms_root"
        sequence="10"
    />

    <menuitem
        id="menu_fms_shifts"
        name="Shifts"
        parent="menu_fms_operations"
        action="action_fms_shift"
        sequence="10"
    />

    <!-- Configuration — master data setup -->
    <menuitem
        id="menu_fms_configuration"
        name="Configuration"
        parent="menu_fms_root"
        sequence="90"
    />

    <menuitem
        id="menu_fms_companies"
        name="Companies"
        parent="menu_fms_configuration"
        action="action_fms_placeholder_companies"
        sequence="10"
    />

    <menuitem
        id="menu_fms_site_preferences"
        name="Site Preferences"
        parent="menu_fms_configuration"
        action="action_fms_site_preferences"
        sequence="20"
    />

    <menuitem
        id="menu_fms_islands"
        name="Islands"
        parent="menu_fms_configuration"
        action="action_fms_island"
        sequence="30"
    />

    <menuitem
        id="menu_fms_pumps"
        name="Pumps"
        parent="menu_fms_configuration"
        action="action_fms_pump"
        sequence="40"
    />

    <menuitem
        id="menu_fms_calibration_charts"
        name="Tank Calibration Charts"
        parent="menu_fms_configuration"
        action="action_fms_calibration_chart"
        sequence="50"
    />

</odoo>
