<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add FMS tank fields to the standard stock.location form -->
    <record id="view_stock_location_fms_form" model="ir.ui.view">
        <field name="name">stock.location.fms.form</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">
            <!-- Append FMS group after the existing "Additional Information" group -->
            <xpath expr="//group[@name='additional_info']" position="after">
                <group string="Forecourt Management (FMS)"
                       name="fms_tank"
                       invisible="usage != 'internal'">
                    <field name="fms_is_fuel_tank" string="Is Fuel Tank"/>
                    <field name="fms_capacity_litres"
                           string="Capacity (L)"
                           invisible="not fms_is_fuel_tank"
                           required="fms_is_fuel_tank"/>
                    <field name="fms_fuel_product_id"
                           string="Fuel Product"
                           invisible="not fms_is_fuel_tank"/>
                    <field name="fms_pts2_tank_number"
                           string="PTS-2 Tank Number"
                           invisible="not fms_is_fuel_tank"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
