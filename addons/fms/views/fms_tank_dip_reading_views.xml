<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         fms.tank.dip.reading — list view
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_fms_tank_dip_reading_list" model="ir.ui.view">
        <field name="name">fms.tank.dip.reading.list</field>
        <field name="model">fms.tank.dip.reading</field>
        <field name="arch" type="xml">
            <list string="Tank Dip Readings"
                  decoration-muted="state == 'confirmed'">
                <field name="shift_id"/>
                <field name="reading_type" widget="badge"
                       decoration-info="reading_type == 'opening'"
                       decoration-warning="reading_type == 'closing'"/>
                <field name="tank_location_id" string="Tank"/>
                <field name="fuel_product_id" string="Fuel"/>
                <field name="dip_height_mm" string="Dip (mm)"/>
                <field name="water_height_mm" string="Water (mm)" optional="show"/>
                <field name="observed_volume_litres" string="Volume (L)"/>
                <field name="temperature_celsius" string="Temp (°C)" optional="show"/>
                <field name="reading_time"/>
                <field name="recorded_by" optional="show"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         fms.tank.dip.reading — form view
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_fms_tank_dip_reading_form" model="ir.ui.view">
        <field name="name">fms.tank.dip.reading.form</field>
        <field name="model">fms.tank.dip.reading</field>
        <field name="arch" type="xml">
            <form string="Tank Dip Reading">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Confirming will interpolate the volume from the calibration chart and lock this record. Continue?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Shift">
                            <field name="shift_id"
                                   domain="[('state', 'not in', ['closed', 'disputed'])]"
                                   options="{'no_create': True}"/>
                            <field name="reading_type"/>
                            <field name="reading_time"/>
                            <field name="recorded_by" options="{'no_create': True}"/>
                        </group>
                        <group string="Tank">
                            <field name="tank_location_id"
                                   domain="[('fms_is_fuel_tank', '=', True), ('active', '=', True)]"
                                   options="{'no_create': True}"/>
                            <field name="fuel_product_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Measurements">
                        <field name="dip_height_mm" string="Dip Height (mm)"/>
                        <field name="water_height_mm" string="Water Height (mm)"/>
                        <field name="temperature_celsius" string="Temperature (°C)"/>
                        <field name="observed_volume_litres" string="Observed Volume (L)"
                               readonly="1"
                               help="Calculated from the dip height using the active calibration chart. Populated on confirmation."/>
                        <field name="confirmed_at" readonly="1"
                               invisible="state != 'confirmed'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         fms.tank.dip.reading — search view
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_fms_tank_dip_reading_search" model="ir.ui.view">
        <field name="name">fms.tank.dip.reading.search</field>
        <field name="model">fms.tank.dip.reading</field>
        <field name="arch" type="xml">
            <search string="Tank Dip Readings">
                <field name="shift_id"/>
                <field name="tank_location_id"/>
                <field name="fuel_product_id"/>
                <separator/>
                <filter name="filter_opening"   string="Opening"
                        domain="[('reading_type', '=', 'opening')]"/>
                <filter name="filter_closing"   string="Closing"
                        domain="[('reading_type', '=', 'closing')]"/>
                <separator/>
                <filter name="filter_draft"     string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_shift"   string="Shift"
                            context="{'group_by': 'shift_id'}"/>
                    <filter name="group_tank"    string="Tank"
                            context="{'group_by': 'tank_location_id'}"/>
                    <filter name="group_product" string="Fuel Product"
                            context="{'group_by': 'fuel_product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         Window action
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="action_fms_tank_dip_reading" model="ir.actions.act_window">
        <field name="name">Tank Dip Readings</field>
        <field name="res_model">fms.tank.dip.reading</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fms_tank_dip_reading_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No dip readings yet.</p>
            <p>Open a shift and record dip heights for each fuel tank at the
               start and end of the operational period.</p>
        </field>
    </record>

</odoo>
